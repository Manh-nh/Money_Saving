<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginTop="8dp"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/indicatorDate"
            android:layout_width="8dp"
            android:layout_height="16dp"
            android:background="@drawable/bg_indicator"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtDateParent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/urbanist_600"
            android:text="Today, 18 march"
            android:textColor="#2D0D59"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/indicatorDate"
            app:layout_constraintEnd_toStartOf="@id/indicatorDate"
            app:layout_constraintTop_toTopOf="@id/indicatorDate" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list_history_child"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        tools:listitem="@layout/item_history_child"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
</LinearLayout>