<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="32dp"
    android:paddingEnd="16dp">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/ic_back" />

        <TextView
            android:id="@+id/titleBudget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/urbanist_600"
            android:text="Budget"
            android:textAlignment="center"
            android:textColor="#2D0D59"
            android:textSize="20sp" />
    </LinearLayout>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/txtBudget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/urbanist_600"
            android:text="Budget"
            android:textColor="#2D0D59"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtMoneyBudget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/urbanist_600"
            android:text="0 đ"
            android:textColor="#772DDF"
            android:textSize="20sp"
            app:layout_constraintStart_toStartOf="@id/txtBudget"
            app:layout_constraintTop_toTopOf="@id/txtBudget" />

        <TextView
            android:id="@+id/btnEditMoneyBudget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/ic_edit"
            app:layout_constraintStart_toEndOf="@id/txtMoneyBudget"
            app:layout_constraintTop_toTopOf="@id/txtMoneyBudget" />
    </androidx.constraintlayout.widget.ConstraintLayout>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="8dp"
        android:elevation="4dp">

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:max="100"
            android:progress="1"
            android:progressDrawable="@drawable/custom_progress"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="76%"
            android:fontFamily="@font/urbanist_600"
            android:textSize="18sp"
            android:textColor="#2D0D59"
            app:layout_constraintVertical_bias="0.6"
            app:layout_constraintTop_toTopOf="@id/progressBar"
            app:layout_constraintBottom_toBottomOf="@id/progressBar"
            app:layout_constraintStart_toStartOf="@id/progressBar"
            app:layout_constraintEnd_toEndOf="@id/progressBar" />

        <TextView
            android:id="@+id/txtProgressTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remain"
            android:fontFamily="@font/urbanist_500"
            android:textSize="14sp"
            android:textColor="#9D89B8"
            app:layout_constraintBottom_toTopOf="@+id/txtProgress"
            app:layout_constraintStart_toStartOf="@id/txtProgress"
            app:layout_constraintEnd_toEndOf="@id/txtProgress" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/txtMoneyBudgetAndExpend"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            app:layout_constraintVertical_bias="0.1"
            android:layout_marginStart="@dimen/_8sdp"
            android:background="@drawable/bg_remain"
            android:elevation="8dp"
            app:layout_constraintBottom_toBottomOf="@id/progressBar"
            app:layout_constraintStart_toEndOf="@id/progressBar"
            app:layout_constraintTop_toTopOf="@id/progressBar">


            <TextView
                android:id="@+id/txtBudgetMoney"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/urbanist_500"
                android:textColor="#2D0D59"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/bgLine"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="8dp"
                android:background="#D0DADD"
                app:layout_constraintTop_toBottomOf="@id/txtBudgetMoney" />

            <TextView
                android:id="@+id/txtExpends"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/urbanist_500"
                android:textColor="#2D0D59"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/bgLine" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/txtRemain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/urbanist_600"
            android:textSize="14sp"
            android:textColor="#2D0D59"
            android:background="@drawable/bg_indicator"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:paddingEnd="16dp"
            android:paddingStart="16dp"
            app:layout_constraintTop_toBottomOf="@+id/txtMoneyBudgetAndExpend"
            app:layout_constraintStart_toStartOf="@+id/txtMoneyBudgetAndExpend"
            app:layout_constraintEnd_toEndOf="@id/txtMoneyBudgetAndExpend"/>


    </androidx.constraintlayout.widget.ConstraintLayout>


    <TextView
        android:id="@+id/btnBudgetDetail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_btn_add_new"
        android:fontFamily="@font/urbanist_500"
        android:padding="16dp"
        android:text="Budget Detail"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="13sp" />

</LinearLayout>