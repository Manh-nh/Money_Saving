<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/btnCategory">

    <ImageView
        android:id="@+id/imgCategory"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_category_selection"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtNameTypeCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/urbanist_500"
        android:textColor="#2D0D59"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="@id/imgCategory"
        app:layout_constraintStart_toStartOf="@id/imgCategory"
        app:layout_constraintTop_toBottomOf="@id/imgCategory" />

</androidx.constraintlayout.widget.ConstraintLayout>