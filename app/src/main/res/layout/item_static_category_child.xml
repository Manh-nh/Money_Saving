<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_item_expend_child">

    <ImageView
        android:id="@+id/imgCategory"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_btn_add_plus"
        android:src="@drawable/ic_hmburger"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.1" />

    <TextView
        android:id="@+id/txtCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:fontFamily="@font/urbanist_600"
        android:text="Food"
        android:textColor="#2D0D59"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@id/imgCategory"
        app:layout_constraintStart_toEndOf="@id/imgCategory"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.1" />

    <ProgressBar
        android:id="@+id/pb_category"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:max="100"
        android:progress="40"
        android:progressTint="#F5C0E1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/txtCategory"
        app:layout_constraintTop_toBottomOf="@id/txtCategory" />


    <TextView
        android:id="@+id/txtTotalMoney"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/urbanist_500"
        android:text="100.000đ"
        android:textColor="#9D89B8"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@id/pb_category"
        app:layout_constraintEnd_toEndOf="@id/pb_category" />


</androidx.constraintlayout.widget.ConstraintLayout>