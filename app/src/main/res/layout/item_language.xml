<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:gravity="center"
    android:padding="@dimen/_8sdp"
    android:background="@drawable/bg_language_item"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/_4sdp">


    <ImageView
        android:id="@+id/imgLanguage"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/russia" />

    <TextView
        android:id="@+id/nameCountry"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="@font/urbanist_500"
        android:text="russia"
        android:layout_marginStart="@dimen/_8sdp"
        android:textColor="#2D0D59" />

    <ImageView
        android:id="@+id/btnChoice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_not_choice"/>

</LinearLayout>