<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="16dp"
    android:orientation="vertical">

    <TextView
        android:id="@+id/txtAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/urbanist_600"
        android:text="Amount"
        android:textColor="#2D0D59"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/edtSetMoney"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edt_search"
        android:hint="0 vnđ"
        android:inputType="number"
        android:imeOptions="actionDone"
        android:textColor="#2D0D59"
        android:textColorHint="#9D89B8" />

    <TextView
        android:id="@+id/txtCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/urbanist_600"
        android:text="Category"
        android:textColor="#2D0D59"
        android:textSize="14sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/lstCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_category"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="4" />

    <TextView
        android:id="@+id/txtBudget"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/urbanist_600"
        android:text="Budget"
        android:textColor="#2D0D59"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/btnBudget"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_budget"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtBudgetSelection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/urbanist_500"
            android:text="Necessities"
            android:textColor="#18181B"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnDownBudget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/ic_down" />

    </LinearLayout>

    <TextView
        android:id="@+id/txtNote"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/urbanist_500"
        android:text="Note"
        android:textColor="#18181B"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/edtNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_note"
        android:fontFamily="@font/urbanist_500"
        android:hint="Add a description"
        android:textColor="#9D89B8"
        android:textSize="14sp" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btnCalender"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_note">

            <TextView
                android:id="@+id/icCalender"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/ic_calender"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Thứ 3, 23 Nov 2024"
                app:layout_constraintBottom_toBottomOf="@id/icCalender"
                app:layout_constraintStart_toEndOf="@id/icCalender"
                app:layout_constraintTop_toTopOf="@id/icCalender" />

        </androidx.constraintlayout.widget.ConstraintLayout>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btnTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_note">

            <TextView
                android:id="@+id/icAlarm"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/ic_alarm"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="12:30"
                app:layout_constraintBottom_toBottomOf="@id/icAlarm"
                app:layout_constraintStart_toEndOf="@id/icAlarm"
                app:layout_constraintTop_toTopOf="@id/icAlarm" />

        </androidx.constraintlayout.widget.ConstraintLayout>


    </LinearLayout>

</LinearLayout>